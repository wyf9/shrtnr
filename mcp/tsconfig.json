{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "declaration": true,
        "outDir": "dist",
        "rootDir": "src",
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "ignoreDeprecations": "6.0"
    },
    "include": [
        "src"
    ],
    "exclude": [
        "src/__tests__"
    ]
}
