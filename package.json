{
  "name": "shrtnr",
  "version": "0.32.0",
  "description": "A free, open-source, self-hosted URL shortener built on Cloudflare Workers + D1",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "bash scripts/resolve-bindings.sh && wrangler deploy",
    "wrangler-login": "wrangler login",
    "db:create": "wrangler d1 create shrtnr-db",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "secret:put": "wrangler secret put",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.1",
    "@cloudflare/workers-types": "^4.20260426.1",
    "@vitest/runner": "^4.1.5",
    "@vitest/snapshot": "^4.1.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.86.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.11.6",
    "hono": "^4.12.15",
    "jose": "^6.2.3",
    "zod": "^4.3.6"
  }
}
