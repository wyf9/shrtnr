{
  "name": "shrtnr",
  "version": "0.35.0",
  "description": "A free, open-source, self-hosted URL shortener built on Cloudflare Workers + D1",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "wrangler-login": "wrangler login",
    "db:create": "wrangler d1 create shrtnr-db",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "secret:put": "wrangler secret put",
    "test": "vitest run",
    "test:watch": "vitest",
    "emit-spec": "tsx scripts/emit-spec.ts"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.1",
    "@cloudflare/workers-types": "^4.20260426.1",
    "@vitest/runner": "^4.1.5",
    "@vitest/snapshot": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.86.0"
  },
  "packageManager": "bun@1.3.10",
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.4.0",
    "@hono/zod-openapi": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.11.6",
    "hono": "^4.12.15",
    "jose": "^6.2.3",
    "zod": "^4.3.6"
  }
}
